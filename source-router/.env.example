# Source Router environment variables
# Copy this file to a local .env or export the variables in your shell.

# GitHub
GITHUB_TOKEN=

# Search aggregation providers
TAVILY_API_KEY=
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=
METASO_API_KEY=
SERPAPI_API_KEY=
SERPER_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=
FIRECRAWL_API_KEY=
TIKHUB_API_KEY=

# Browser-use MCP fallback (executed by the AI agent, not directly by Python)
BROWSER_USE_PROFILE=

# Source Router runtime config
SOURCE_ROUTER_TIMEOUT=20
SOURCE_ROUTER_MAX_RESULTS=8
SOURCE_ROUTER_MODE=
SOURCE_ROUTER_BUDGET=medium
SOURCE_ROUTER_LANGUAGE=zh-CN
SOURCE_ROUTER_COUNTRY=CN
